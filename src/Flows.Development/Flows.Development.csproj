<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Flows.Development</RootNamespace>
    <AssemblyName>Flows.Development</AssemblyName>

    <!-- Native AOT: binário nativo autocontido, sem dependência do runtime .NET.
         Publique com um RID: dotnet publish -c Release -r osx-arm64 (ou linux-x64, win-x64). -->
    <PublishAot>true</PublishAot>
    <InvariantGlobalization>true</InvariantGlobalization>
    <StripSymbols>true</StripSymbols>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Harness.Engine\Harness.Engine.csproj" />
  </ItemGroup>

</Project>
